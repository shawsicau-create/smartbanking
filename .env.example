# SmartBanking 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到版本控制系统

# MCP 服务器配置
# 邮件服务器配置
EMAIL_PASSWORD=your_email_password_here
EMAIL_USER=your_email@example.com

# 高德地图 API
AMAP_MAPS_API_KEY=your_amap_api_key_here

# 其他可能的环境变量
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# EdgeOne Pages API Token（部署必需）
# 获取地址：https://pages.edgeone.ai/document/api-token
EDGEONE_PAGES_API_TOKEN=your_edgeone_pages_api_token_here

# 百度站长平台主动推送 Token（SEO 加速必需）
# 获取方式：登录 https://ziyuan.baidu.com/ → 站点管理 → 链接提交 → 主动推送 (实时)
# 形如：abc123def456（不含 site 参数，site 参数已硬编码为 https://smartbanking.edgeone.app）
BAIDU_PUSH_TOKEN=your_baidu_push_token_here
